# GitHub personal access token (classic or fine-grained, public-repo read).
# Optional for low-volume use, but strongly recommended: unauthenticated GitHub
# API requests are limited to 60/hour, authenticated to 5000/hour.
GITHUB_TOKEN=

# --- Web app persistence ---
# The web store auto-selects its backend:
#   - If TURSO_DATABASE_URL is set, it uses remote libSQL (Turso) — for serverless.
#   - Otherwise it uses a local SQLite file at REPOBRIEF_DB_PATH (zero-config dev).
REPOBRIEF_DB_PATH=./repobrief.sqlite

# Remote libSQL / Turso (leave blank for local SQLite).
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Demo seed endpoint (POST /api/demo/seed). When set, the request must send a
# matching x-seed-token header. In production the endpoint is DISABLED unless this
# is set (default-closed); outside production it is open for local seeding.
SEED_TOKEN=

# --- Hosted abuse limits (optional; sensible defaults applied when unset) ---
# Per-IP rate limit, global analysis concurrency cap, and max queued jobs for
# POST /api/briefs. State is in-memory/per-instance — back it with a shared store
# / durable queue for multi-replica setups.
BRIEFS_RATE_LIMIT=10
BRIEFS_RATE_WINDOW_MS=60000
BRIEFS_MAX_CONCURRENT=2
BRIEFS_MAX_QUEUE=100

# Ingestion ceilings for the hosted surface (bytes / file count). Lower than the
# CLI defaults so a giant public repo can't exhaust server memory.
INGEST_MAX_ARCHIVE_BYTES=60000000
INGEST_MAX_FILE_COUNT=25000
INGEST_MAX_TOTAL_TEXT_BYTES=80000000
