{
  "name": "@repobrief/core",
  "version": "0.1.0",
  "description": "RepoBrief analysis engine: ingest a repo and produce an architecture map, hotspots, and a reading path.",
  "license": "MIT",
  "author": "Conal",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/conalh/repo-brief.git",
    "directory": "packages/core"
  },
  "keywords": [
    "repository",
    "analysis",
    "architecture",
    "onboarding",
    "github"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "tsc -p tsconfig.json"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^2.1.9",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "dependencies": {
    "nanotar": "^0.3.0",
    "smol-toml": "^1.6.1",
    "yaml": "^2.9.0"
  }
}
